    "test:integration": "cross-env NODE_OPTIONS=--use-system-ca vitest run src/__tests__/integration",
    "test:watch": "cross-env NODE_OPTIONS=--use-system-ca vitest",
    "test:coverage": "cross-env NODE_OPTIONS=--use-system-ca vitest run --coverage"
  },
  "dependencies": {
