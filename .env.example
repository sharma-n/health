# ── Health App configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. See SPEC.md §9.2.

# SQLite database location.
#   Local dev:  file:./dev.db          (resolved relative to prisma/)
#   Docker:     file:/data/app.db      (mounted named volume)
DATABASE_URL="file:./dev.db"

# Auth.js JWT signing secret. REQUIRED. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# Set to "false" to disable open sign-up after creating your account(s).
ALLOW_REGISTRATION="true"

# HTTP port the server listens on.
PORT="3000"

# ── AI Coach (Milestone 10+) ─────────────────────────────────────────────────
# URL of the Python agent sidecar. Local dev: http://localhost:8000
# Docker Compose: http://agent_service:8000 (set automatically in compose).
AGENT_SERVICE_URL="http://localhost:8000"

# Shared secret between Next.js and the Python sidecar. Generate with:
#   openssl rand -base64 32
INTERNAL_API_SECRET="replace-me-random-secret"

# Anthropic API key for the agent LLM (claude-haiku-4-5-20251001).
ANTHROPIC_API_KEY="sk-ant-..."

# Local LM Studio embedding server (used for episodic memory in M14+).
EMBED_BASE_URL="http://localhost:1234"
EMBED_MODEL="text-embedding-qwen3-embedding-0.6b"
